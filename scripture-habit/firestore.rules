rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated and email verified (if using password provider)
    function isAuthenticated() {
      return request.auth != null && (
        request.auth.token.firebase.sign_in_provider != 'password' || 
        request.auth.token.email_verified == true
      );
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // A user can create their own document upon signup (before email verification)
      allow create: if request.auth != null && request.auth.uid == userId;

      // A user can read a specific user document (needed for group members list).
      // Sensitive data like fcmTokens is now stored in the 'private' subcollection.
      allow get: if request.auth != null;
      allow list: if false;

      // A user can update or delete their own document.
      allow update, delete: if request.auth != null && request.auth.uid == userId;

      // Rules for private user data (e.g. fcmTokens)
      match /private/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Rules for the 'notes' subcollection
      match /notes/{noteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Rules for the 'groupStates' subcollection
      match /groupStates/{groupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Rules for the 'letters' subcollection
      match /letters/{letterId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Rules for the 'groups' collection
    match /groups/{groupId} {
      // GET: Allow reading a specific group if public, or if the user is a member/owner
      allow get: if isAuthenticated() && (
        resource.data.isPublic == true ||
        request.auth.uid in resource.data.get('members', []) ||
        resource.data.get('ownerUserId', '') == request.auth.uid
      );
      
      // LIST: Only allow querying public groups, never all groups unconditionally
      allow list: if request.auth != null && resource.data.isPublic == true;

      // A user can create a group, but they must set themselves as the owner.
      allow create: if isAuthenticated() &&
                    request.auth.uid == request.resource.data.ownerUserId;
      
      // 更新権限 (Update rules)
      allow update: if isAuthenticated() && (
        // A. Owner can change anything
        resource.data.get('ownerUserId', '') == request.auth.uid ||
        // B. Members can only update their read access, stats, or leave
        (
          request.auth.uid in resource.data.get('members', []) &&
          // Updating stats / member activity (whitelisted fields only)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'memberLastActive', 'memberLastReadAt', 'messageCount', 
            'lastMessageAt', 'lastNoteAt', 'lastMessageByNickname', 
            'lastMessageByUid', 'lastNoteByNickname', 'lastNoteByUid',
            'noteCount', 'notes', 'lastUnityAnnouncementDate'
          ])
        )
      );
      
      // Allow deletion if the user is the owner
      allow delete: if isAuthenticated() && resource.data.get('ownerUserId', '') == request.auth.uid;
      
      // Rules for the 'messages' subcollection
      match /messages/{messageId} {
        // Members and owner can read messages
        allow read: if isAuthenticated() &&
                    (
                      request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('members', []) ||
                      get(/databases/$(database)/documents/groups/$(groupId)).data.get('ownerUserId', '') == request.auth.uid
                    );
                    
        // Members and owner can create messages
        allow create: if isAuthenticated() &&
                    (
                      request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('members', []) ||
                      get(/databases/$(database)/documents/groups/$(groupId)).data.get('ownerUserId', '') == request.auth.uid
                    ) &&
                    (
                      request.resource.data.senderId == request.auth.uid || 
                      (request.resource.data.senderId == 'system' && request.resource.data.isSystemMessage == true)
                    );
                    
        // Only the sender (or owner) can update/delete messages, 
        // EXCEPT for reactions which any member can update.
        allow update: if isAuthenticated() &&
                      (
                        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('members', []) ||
                        get(/databases/$(database)/documents/groups/$(groupId)).data.get('ownerUserId', '') == request.auth.uid
                      ) &&
                      (
                        // Case 1: Sender or Owner updating the message content/metadata
                        (
                          (resource.data.senderId == request.auth.uid || get(/databases/$(database)/documents/groups/$(groupId)).data.get('ownerUserId', '') == request.auth.uid) &&
                          // Prevent changing senderId
                          request.resource.data.senderId == resource.data.senderId
                        ) ||
                        // Case 2: Any member updating ONLY reactions
                        (
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
                        )
                      );
                      
        allow delete: if isAuthenticated() &&
                      (
                        resource.data.senderId == request.auth.uid ||
                        get(/databases/$(database)/documents/groups/$(groupId)).data.get('ownerUserId', '') == request.auth.uid
                      );
      }
    }

    // Rules for the 'system' collection (Maintenance & Status)
    match /system/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Rules for the 'cheers' collection
    match /cheers/{cheerId} {
      allow read: if request.auth != null && (
        resource.data.senderUid == request.auth.uid || 
        resource.data.targetUid == request.auth.uid
      );
      allow write: if false;
    }

    // Rules for the 'reports' collection
    match /reports/{reportId} {
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if false; // Only admins via backend can read/manage
    }
  }
}
